{
  "name": "@cocuyo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf .next dist out coverage",
    "serve": "npx serve dist",
    "deploy": "dotns bulletin upload ./dist --parallel --print-contenthash"
  },
  "dependencies": {
    "@cocuyo/bulletin": "workspace:*",
    "@cocuyo/identity": "workspace:*",
    "@cocuyo/types": "workspace:*",
    "@cocuyo/ui": "workspace:*",
    "@novasamatech/host-api": "0.6.6-1",
    "@novasamatech/product-sdk": "0.6.6-1",
    "@polkadot-labs/hdkd-helpers": "^0.0.27",
    "next": "^15.1.0",
    "polkadot-api": "1.23.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^3.1.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.1.0"
  }
}
