{
  "name": "@cocuyo/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Smart contracts for the Firefly Network",
  "exports": {
    "./artifacts/BountyEscrow.json": "./artifacts/contracts/BountyEscrow.sol/BountyEscrow.json",
    "./artifacts/FireflyReputation.json": "./artifacts/contracts/FireflyReputation.sol/FireflyReputation.json",
    "./typechain-types": "./typechain-types/index.ts",
    "./typechain-types/*": "./typechain-types/*.ts"
  },
  "scripts": {
    "download:binaries": "bash scripts/download-binaries.sh",
    "build": "hardhat compile",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:paseo": "hardhat run scripts/deploy.ts --network paseo",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "verify": "hardhat verify",
    "clean": "hardhat clean && rm -rf typechain-types",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix --noPrompt",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cocuyo/types": "workspace:*"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "5.4.0",
    "@openzeppelin/contracts-upgradeable": "5.4.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@parity/hardhat-polkadot": "0.2.7",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "chai": "^4.3.10",
    "dotenv": "^16.4.5",
    "ethers": "^6.10.0",
    "hardhat": "^2.28.2",
    "hardhat-gas-reporter": "^1.0.9",
    "solhint": "^4.1.1",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
